{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": "src",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
