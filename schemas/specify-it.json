{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/specify-it@0.6.0/schemas/specify-it.json",
  "title": "Specify It Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "specs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum": ["md", "json", "html", "xml"]
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "naming": {
          "type": "string",
          "enum": [
            "timestamp-slug",
            "slug",
            "sequence-slug",
            "date-slug",
            "datetime-slug",
            "group-timestamp-slug",
            "timestamp-group-slug",
            "group-slug"
          ]
        },
        "groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sections": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "order": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "optional": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": ["order", "required", "optional"]
        }
      },
      "required": ["root", "format", "language", "naming", "sections"]
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "syncDocuments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["syncDocuments"]
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireSpecsDirectory": {
          "type": "boolean"
        },
        "requireOrderedSections": {
          "type": "boolean"
        },
        "requireKnownExtension": {
          "type": "boolean"
        },
        "commitSpecs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "one", "any"]
            },
            "maxChangedSpecs": {
              "type": "integer",
              "minimum": 1
            },
            "requireLatest": {
              "type": "boolean"
            }
          },
          "required": ["mode", "requireLatest"]
        }
      },
      "required": ["requireSpecsDirectory", "requireOrderedSections", "requireKnownExtension"]
    }
  },
  "required": ["specs", "agents", "checks"]
}
