{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "commitArgs": ["--no-verify"],
    "commitMessage": "chore(release): release ${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": true,
    "skipChecks": true
  },
  "github": {
    "release": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "angular"
      }
    }
  }
}
